      "default": "avulso",
      "description": "Se o servi\u00e7o \u00e9 coberto pelo plano ou cobrado avulso"
    },
    "id_pet_shop": {
      "type": "string",
      "description": "ID do Pet Shop"
    }
  },
  "required": [
    "data_hora",
    "servico",
    "id_cliente",
    "id_pet"
  ]
}