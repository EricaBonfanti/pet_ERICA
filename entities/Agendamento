{
  "name": "Agendamento",
  "type": "object",
  "properties": {
    "data_hora": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora do agendamento"
    },
    "servico": {
      "type": "string",
      "enum": [
        "Banho",
        "Tosa",
        "Hidrata\u00e7\u00e3o",
        "Corte de unha",
        "Limpeza de ouvido"
      ],
      "description": "Tipo de servi\u00e7o"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pendente",
        "Confirmado",
        "Concluido",
        "Cancelado"
