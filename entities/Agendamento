    },
    "id_cliente": {
      "type": "string",
      "description": "ID do cliente (User)"
    },
    "id_pet": {
      "type": "string",
      "description": "ID do pet"
    },
    "nome_pet": {
      "type": "string",
      "description": "Nome do pet"
    },
    "nome_cliente": {
      "type": "string",
      "description": "Nome do cliente"
    },
    "observacoes": {
      "type": "string"
    },
    "valor": {
      "type": "number",
      "description": "Valor do servi\u00e7o"
    },
    "tipo_cobranca": {
      "type": "string",
      "enum": [
        "coberto_pelo_plano",
        "avulso"
